<Window x:Class="_5Elem.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{StaticResource AppTitle}" 
        SizeToContent="Height"
        Width="{StaticResource DialogsWidth}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding LoginCommand}" />
    </Window.InputBindings>

    <Grid>
        <Border Background="{StaticResource DarkBackgroundBrush}" 
                CornerRadius="20" 
                Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Content="{StaticResource CloseButtonText}"
                        Style="{StaticResource CloseButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-20,0,0"
                        Command="{Binding CloseCommand}"/>

                <TextBlock Text="{StaticResource AppTitle}" 
                            FontSize="{StaticResource TitleFontSize}"
                            FontWeight="Bold"
                            Foreground="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,30"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" 
                            HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Button Content="{StaticResource LoginTab}" 
                            Command="{Binding SwitchModeCommand}"
                            FontSize="{StaticResource ButtonFontSize}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLoginMode}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="/" 
                                Foreground="{StaticResource TextSecondaryBrush}"
                                HorizontalAlignment="Center"
                                Margin="5,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource ButtonFontSize}"/>

                    <Button Content="{StaticResource RegisterTab}" 
                            Command="{Binding SwitchModeCommand}"
                            FontSize="{StaticResource ButtonFontSize}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLoginMode}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" 
                            Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBox Text="{Binding LoginModel.Username, UpdateSourceTrigger=PropertyChanged}" 
                                Style="{StaticResource ModernTextBox}"
                                Margin="0,0,0,15"
                                Tag="{StaticResource UsernamePlaceholder}"
                                FontSize="{StaticResource BodyFontSize}"/>

                    <PasswordBox x:Name="LoginPassword" 
                                    Style="{StaticResource ModernPasswordBox}"
                                    Margin="0,0,0,25"
                                    Tag="{StaticResource PasswordPlaceholder}"
                                    PasswordChanged="PasswordChanged"
                                    FontSize="{StaticResource BodyFontSize}"/>

                    <Button Content="{StaticResource LoginButtonText}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            FontSize="{StaticResource ButtonFontSize}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" 
                            Visibility="{Binding IsLoginMode, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBox Text="{Binding LoginModel.Username, UpdateSourceTrigger=PropertyChanged}" 
                                Style="{StaticResource ModernTextBox}"
                                Margin="0,0,0,15"
                                Tag="{StaticResource UsernamePlaceholder}"
                                FontSize="{StaticResource BodyFontSize}"/>

                    <TextBox Text="{Binding LoginModel.Email, UpdateSourceTrigger=PropertyChanged}" 
                                Style="{StaticResource ModernTextBox}"
                                Margin="0,0,0,15"
                                Tag="{StaticResource EmailPlaceholder}"
                                FontSize="{StaticResource BodyFontSize}"/>

                    <PasswordBox x:Name="RegisterPassword"
                                    Style="{StaticResource ModernPasswordBox}"
                                    Margin="0,0,0,15"
                                    Tag="{StaticResource PasswordPlaceholder}"
                                    PasswordChanged="PasswordChanged"
                                    FontSize="{StaticResource BodyFontSize}"/>

                    <PasswordBox x:Name="RegisterConfirmPassword" 
                                    Style="{StaticResource ModernPasswordBox}"
                                    Margin="0,0,0,25"
                                    Tag="{StaticResource ConfirmPasswordPlaceholder}"
                                    PasswordChanged="ConfirmPasswordChanged"
                                    FontSize="{StaticResource BodyFontSize}"/>

                    <Button Content="{StaticResource RegisterButtonText}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RegisterCommand}"
                            FontSize="{StaticResource ButtonFontSize}"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" 
                            Grid.Row="3"
                            Foreground="Red"
                            TextWrapping="Wrap"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource SmallFontSize}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
