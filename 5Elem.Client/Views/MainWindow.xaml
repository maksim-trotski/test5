<Window x:Class="_5Elem.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:_5Elem.Client.ViewModels"
        Title="{StaticResource CatalogTitle}"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        x:Name="MainWindowRoot">

    <Window.Resources>
        
        <DataTemplate DataType="{x:Type viewModels:CategoryItemViewModel}">
            <Border Style="{StaticResource CategoryCard}" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding ClickCommand}"
                                  CommandParameter="{Binding}"
                                  MouseAction="LeftClick"/>
                </Border.InputBindings>

                <Grid Width="{StaticResource CardWidth}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{StaticResource ImageHeight}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Source="{Binding ThumbnailUrl}"
                           Stretch="UniformToFill"
                           Grid.Row="0"
                           Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding Name}"
                               Grid.Row="1"
                               FontSize="{StaticResource FontNormal}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextAlignment="Center"
                               Margin="10,5"/>

                    <TextBlock Text="{Binding ProductsCount, StringFormat={StaticResource ProductsCountFormat}}"
                               Grid.Row="2"
                               FontSize="{StaticResource FontSmall}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Center"
                               Margin="10,0,10,10"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,5,5,0">

                        <Button Content="{StaticResource EditIcon}"
                                Style="{StaticResource IconButton}"
                                Command="{Binding EditCategoryCommand}"
                                CommandParameter="{Binding}"/>

                        <Button Content="{StaticResource DeleteIcon}"
                                Style="{StaticResource IconButton}"
                                Margin="5,0,0,0"
                                Command="{Binding DeleteCategoryCommand}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ProductItemViewModel}">
            <Border Style="{StaticResource ProductCard}">
                <Grid Width="{StaticResource CardWidth}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{StaticResource ImageHeight}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Source="{Binding ThumbnailUrl}"
                           Stretch="UniformToFill"
                           Grid.Row="0"
                           Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding Name}"
                               Grid.Row="1"
                               FontSize="{StaticResource FontNormal}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextAlignment="Center"
                               Margin="10,5"/>

                    <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}"
                               Grid.Row="2"
                               FontSize="{StaticResource FontLarge}"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               TextAlignment="Center"
                               Margin="10,0"/>

                    <TextBlock Text="{Binding Stock, StringFormat={StaticResource StockFormat}}"
                               Grid.Row="3"
                               FontSize="{StaticResource FontSmall}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Center"
                               Margin="10,0,10,10"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,5,5,0">

                        <Button Content="{StaticResource EditIcon}"
                                Style="{StaticResource IconButton}"
                                Command="{Binding EditProductCommand}"
                                CommandParameter="{Binding}"/>

                        <Button Content="{StaticResource DeleteIcon}"
                                Style="{StaticResource IconButton}"
                                Margin="5,0,0,0"
                                Command="{Binding DeleteProductCommand}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource DarkBackgroundBrush}" 
                CornerRadius="{StaticResource CornerRadius}">
            <Grid Margin="{StaticResource BorderPadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="{StaticResource SecondaryCornerRadius}"
                        Padding="15,10"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <Button Content="{StaticResource BreadcrumbRoot}"
                                    Style="{StaticResource NavButton}"
                                    Command="{Binding NavigateToRootCommand}"/>

                            <TextBlock Text="{StaticResource BreadcrumbSeparator}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontBreadcrumb}"
                                       Margin="5,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding CurrentCategory, Converter={StaticResource NullToVisibility}}"/>

                            <TextBlock Text="{Binding CurrentCategoryName}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="{StaticResource FontNormal}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding CurrentCategory, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Username}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">

                            <Button Content="{StaticResource AddProduct}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AddProductCommand}"/>

                            <Button Content="{StaticResource AddCategory}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="10,0,0,0"
                                    Command="{Binding AddCategoryCommand}"/>

                            <Button Content="{StaticResource Logout}"
                                    Style="{StaticResource DangerButton}"
                                    Margin="10,0,0,0"
                                    Command="{Binding LogoutCommand}"/>

                            <Button Content="{StaticResource CloseButtonText}"
                                    Style="{StaticResource CloseButton}"
                                    Margin="10,0,0,0"
                                    Command="{Binding CloseCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <TextBlock Text="{Binding StatusMessage}"
                           Grid.Row="1"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,10"
                           Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"/>

                <TextBlock Text="{StaticResource LoadingText}"
                           Grid.Row="1"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,10"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                <ScrollViewer Grid.Row="1"
                              Margin="0,30,0,0"
                              VerticalScrollBarVisibility="Auto">

                    <ItemsControl ItemsSource="{Binding DisplayItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,20,0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>