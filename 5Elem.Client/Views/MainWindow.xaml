<Window x:Class="_5Elem.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог товаров" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Border Background="{StaticResource DarkBackgroundBrush}" 
                CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Верхняя панель -->
                <Border Grid.Row="0" 
                        Background="{StaticResource SurfaceBrush}" 
                        CornerRadius="10"
                        Padding="15,10"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Каталог товаров" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Username}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="+ Добавить товар"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AddProductCommand}"/>
                            <Button Content="📁 Категории"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="10,0,0,0"
                                    Command="{Binding OpenCategoriesCommand}"/> 

                            <Button Content="Выйти"
                                    Style="{StaticResource DangerButton}"
                                    Margin="10,0,0,0"
                                    Command="{Binding LogoutCommand}"/>

                            <Button Content="✕"
                                    Style="{StaticResource CloseButton}"
                                    Margin="10,0,0,0"
                                    Command="{Binding CloseCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Статус -->
                <TextBlock Grid.Row="1" 
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,10"
                           Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"/>

                <TextBlock Grid.Row="1" 
                           Text="Загрузка..."
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,0,0,10"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Список товаров -->
                <ScrollViewer Grid.Row="1" 
                              Margin="0,30,0,0"
                              Style="{StaticResource ModernScrollViewer}"
                              VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding Products}"
                             SelectedItem="{Binding SelectedProduct}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" 
                                          HorizontalAlignment="Left"
                                          Margin="0,0,20,0"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProductCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="200"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Image Source="{Binding ImageUrl}" 
                                               Stretch="UniformToFill"
                                               Grid.Row="0"
                                               Margin="0,0,0,10"/>

                                        <TextBlock Text="{Binding Name}" 
                                                   Grid.Row="1"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="10,0"/>

                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}" 
                                                   Grid.Row="2"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Margin="10,5,0,0"/>

                                        <TextBlock Text="{Binding Stock, StringFormat='В наличии: {0} шт.'}" 
                                                   Grid.Row="3"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="10,0,0,10"/>

                                        <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,5,5,0">
                                            <Button Content="✎" 
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑" 
                                                    Style="{StaticResource IconButton}"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
