<Window x:Class="_5Elem.Client.Dialogs.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        SizeToContent="Height"
        Width="{StaticResource DialogsWidth}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Border Background="{StaticResource DarkBackgroundBrush}" 
                CornerRadius="{StaticResource CornerRadius}"
                Padding="{StaticResource BorderPadding}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Content="{StaticResource CloseButtonText}"
                        Style="{StaticResource CloseButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-20,0,0"
                        Command="{Binding CloseCommand}"/>

                <TextBlock Text="{Binding Title}" 
                           FontSize="{StaticResource TitleFontSize}" 
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="10,0,0,20"/>

                <TextBox Text="{Binding Product.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="1"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,15"
                         Tag="{DynamicResource ProductNamePlaceholder}"/>

                <ComboBox Grid.Row="2"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource ModernComboBox}"
                          Margin="0,0,0,15"
                          Tag="{DynamicResource ProductCategoryPlaceholder}">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>

                <TextBox Text="{Binding Product.Description, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="3"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,15"
                         Tag="{DynamicResource ProductDescriptionPlaceholder}"
                         Height="{StaticResource DescriptionHeight}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>

                <TextBox Text="{Binding Product.Price, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="4"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,15"
                         Tag="{DynamicResource ProductPricePlaceholder}"/>

                <TextBox Text="{Binding Product.Stock, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="5"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,15"
                         Tag="{DynamicResource ProductStockPlaceholder}"/>

                <Button Content="{StaticResource SelectImageButton}"
                        Grid.Row="6"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding SelectImageCommand}"
                        Margin="0,0,0,10"/>

                <TextBlock Text="{Binding ImageName}" 
                           Grid.Row="7"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,20"
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding ErrorMessage}" 
                           Grid.Row="8"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>

                <StackPanel Grid.Row="9" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button Content="{StaticResource CancelButton}" 
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"/>

                    <Button Content="{StaticResource SaveButton}" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>