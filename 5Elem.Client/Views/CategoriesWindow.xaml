<Window x:Class="_5Elem.Client.Views.CategoriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление категориями" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Border Background="{StaticResource DarkBackgroundBrush}" CornerRadius="20" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Категории товаров" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <Button Content="+ Добавить категорию" 
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right"
                            Command="{Binding AddCategoryCommand}"/>
                </Grid>

                <!-- Список категорий -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CategoryCard}" Width="250" Margin="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="150"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Image Source="{Binding ThumbnailUrl}" 
                                               Stretch="UniformToFill"
                                               Grid.Row="0"
                                               Margin="0,0,0,10"/>

                                        <TextBlock Text="{Binding Name}" 
                                                   Grid.Row="1"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="10,0"/>

                                        <TextBlock Text="{Binding ProductsCount, StringFormat='Товаров: {0}'}" 
                                                   Grid.Row="2"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="10,5,0,10"/>

                                        <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,5,5,0">
                                            <Button Content="✎" 
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding DataContext.EditCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑" 
                                                    Style="{StaticResource IconButton}"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Content="✕" Style="{StaticResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-10,0,0" Command="{Binding CloseCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>