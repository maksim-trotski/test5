<Window x:Class="_5Elem.Client.Views.LoginWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding LoginCommand}" CommandParameter="{Binding}" />
    </Window.InputBindings>

    <Grid>
        <Border Background="{StaticResource DarkBackgroundBrush}" 
                CornerRadius="20" 
                Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Каталог товаров" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" 
                            HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Button Content="Вход" 
                            Command="{Binding SwitchModeCommand}">
                        <!--<Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                <Setter Property="Foreground" Value="{Binding IsLoginMode, 
                                    Converter={StaticResource BooleanToBrushConverter}, 
                                    ConverterParameter={StaticResource PrimaryBrush}}"/>
                            </Style>
                        </Button.Style>-->
                    </Button>
                    <Button Content="Регистрация" 
                            Command="{Binding SwitchModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                <Setter Property="Foreground" Value="{Binding IsLoginMode, 
                                    Converter={StaticResource BooleanToBrushConverter}, 
                                    ConverterParameter={StaticResource TextSecondaryBrush}}"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBox Text="{Binding LoginModel.Username, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"
                             Tag="Имя пользователя"/>

                    <PasswordBox x:Name="LoginPassword" 
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,25"
                                 Tag="Пароль"
                                 PasswordChanged="PasswordChanged">
                    </PasswordBox>

                    <Button Content="Войти"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Visibility="{Binding IsLoginMode, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBox Text="{Binding LoginModel.Username, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"
                             Tag="Имя пользователя"/>

                    <TextBox Text="{Binding LoginModel.Email, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"
                             Tag="Email"/>

                    <PasswordBox x:Name="RegisterPassword"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,15"
                                 Tag="Пароль"
                                 PasswordChanged="PasswordChanged">
                    </PasswordBox>

                    <PasswordBox x:Name="RegisterConfirmPassword" 
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,25"
                                 Tag="Подтверждение пароля"
                                 PasswordChanged="ConfirmPasswordChanged">
                    </PasswordBox>

                    <Button Content="Зарегистрироваться"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RegisterCommand}"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" 
                           Grid.Row="4"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>

                <Button Content="✕"
                        Grid.Row="5"
                        Style="{StaticResource CloseButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-20,0,0"
                        Command="{Binding CloseCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>