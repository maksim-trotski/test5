<Window x:Class="_5Elem.Client.Dialogs.CustomMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:_5Elem.Client.Converters"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Border Background="{StaticResource DarkBackgroundBrush}" 
            CornerRadius="20"
            Padding="25">

        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Title}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock Grid.Row="1"
                       Text="{Binding Message}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,0,0,25"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center">

                <Button Content="Да"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding ShowYesButton, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding YesCommand}"
                        Width="100"
                        Margin="0,0,10,0"/>

                <Button Content="Нет"
                        Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding ShowNoButton, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding NoCommand}"
                        Width="100"
                        Margin="0,0,10,0"/>

                <Button Content="OK"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding ShowOkButton, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding OkCommand}"
                        Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>